{
  "manifest_version": 3,
  "name": "Framecast — Frame Interpolation",
  "version": "0.1.0",
  "description": "Real-time 2-4x frame interpolation for any <video> (own WebGPU runtime, runs fully on your GPU)",
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["rt/*", "assets/*"],
      "matches": ["<all_urls>"]
    }
  ],
  "icons": {}
}
